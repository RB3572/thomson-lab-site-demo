# Copy to .env.local for local dev, and set the same keys in the Vercel
# project (Settings → Environment Variables). Never commit real values.

# Google OAuth — Google Cloud Console → APIs & Services → Credentials → your
# OAuth 2.0 "Web application" client.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secret used to sign the session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET=

# Neon Postgres connection string. The Vercel ↔ Neon integration sets this
# automatically (DATABASE_URL / POSTGRES_URL); only set it here for local dev.
DATABASE_URL=

# Optional overrides (defaults are baked into server/config.ts)
# ADMIN_EMAILS=rishi.bhargav@gmail.com,rbhargav@caltech.edu
# SECURE_DRIVE_URL=https://drive.google.com/drive/folders/1BxogjHqLs1fC6wi9jX6YTsIqpllGJ3uV?usp=sharing
